{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile",
      "type": "shell",
      "command": "javac",
      "args": [
        "${fileDirname}\\${fileBasenameNoExtension}.java"
      ],
      "options": {
        "env": {
          "JAVA_HOME": "C:\\Program Files\\Java\\jdk-26",
          "PATH": "C:\\Program Files\\Java\\jdk-26\\bin;${env:PATH}"
