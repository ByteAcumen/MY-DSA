      "options": {
        "env": {
          "JAVA_HOME": "C:\\Program Files\\Java\\jdk-26",
          "PATH": "C:\\Program Files\\Java\\jdk-26\\bin;${env:PATH}"
        }
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": []
    }
  ]
}
